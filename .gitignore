# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Geheimnisse / lokale Konfiguration
*.env
.env
.env.*
!.env.example

# Urheberrechtlich geschützte Quellmaterialien (z. B. Forschungs-PDFs der
# zitierten Literatur) und daraus extrahierte Texte dürfen NIE eingecheckt
# werden – ProcWorks übernimmt nur Konzepte, keinen geschützten Volltext.
*.pdf
*.extracted.txt
*.extract.txt

# Vertrauliche, NICHT zu veröffentlichende Interna (rechtliche Recherchen,
# FTO-/Patentanalysen, Strategie-Notizen). Bleibt ausschließlich lokal.
private/

# Werbe-Website (procworks.de): wird separat und manuell auf einem Webserver
# bereitgestellt und bewusst NICHT im öffentlichen Repository geführt.
/site/

# Reine Entwicklungs-/Projektinterna – das öffentliche Repository ist zugleich der
# Download-Ort für Testnutzer und Kunden, daher bleiben ausschließlich
# kundenrelevante Inhalte sichtbar. Diese Dateien (Marketing/SEO, Veröffentlichungs-
# prozess, Entwickler-Werkzeuge, lokale Editor-Konfiguration, Test-/Smoke-Artefakte)
# bleiben ausschließlich lokal.
*.db
/tools/
/ProcWorks.code-workspace
/docs/Marketing-Konzept.md
/docs/GitHub-Veroeffentlichung.md

