# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
*.egg

# Virtuelle Umgebungen
.venv/
venv/
env/
ENV/

# Test- / Tooling-Caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
